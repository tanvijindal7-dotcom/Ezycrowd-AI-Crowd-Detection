# Ezycrowd Environment Variables
# Copy this file to .env and adjust values as needed.

# Server configuration
PORT=8000
HOST=0.0.0.0

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Enable auto-reload for development (disable in production)
RELOAD=false

# Comma-separated list of allowed CORS origins
# Use * to allow all (development only). In production, set your frontend URL.
ALLOWED_ORIGINS=*
